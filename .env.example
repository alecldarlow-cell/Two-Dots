# Two Dots — Environment Variables
#
# Copy this file to `.env` and populate with real values.
# `.env` is gitignored. Do not commit real keys.
#
# EXPO_PUBLIC_* variables are exposed to the app at runtime.
# The anon key is safe to ship — RLS policies in Supabase gate all access.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
