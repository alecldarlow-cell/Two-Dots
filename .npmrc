# Two Dots needs --legacy-peer-deps for every npm install because
# @testing-library/react-native@^12.5.0 declares a peer dep on
# react-test-renderer that pulls in react@^19, conflicting with the
# project's react@18.2.0 (pinned via expo SDK 51).
#
# Setting it here means npm respects it everywhere — local, EAS Build
# cloud, CI — without anyone needing to remember the --legacy-peer-deps
# flag. Replace this with proper version alignment when the project
# moves off SDK 51 / react@18.
legacy-peer-deps=true
